# --- Supabase (public) --- used by browser client, server components, and middleware
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# --- Supabase (private) --- used by admin client in cron job only; not needed for local dev unless testing cron
SUPABASE_SECRET_KEY=
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=

# --- Google OAuth (public) --- used by browser client for Google One-Tap and Supabase OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- Email --- cron sends to CRON_ERROR_EMAIL: rating-day run digest (every rebalance) and error alerts on non-rating days
EMAIL_HOST=smtp.gmail.com
EMAIL_USER=tryaitrader@gmail.com
EMAIL_PASS=
CRON_ERROR_EMAIL=tryaitrader@gmail.com

# --- AI Keys --- 
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# --- Cron Secret --- used by cron job to authenticate
CRON_SECRET=

# --- AI Concurrency --- number of parallel OpenAI requests during cron run. Crons have 300s timeout on hobby plan
# Set the limit lower if you're worried about OpenAI rate limits (if on a low usage tier)
AI_CONCURRENCY=102

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Dashboard → Settings → Billing → Customer portal:
# - Enable customers to switch plans (Supporter / Outperformer prices on one product or compatible products).
# - Configure upgrade proration (immediate) and downgrade/cancel timing (e.g. at period end) per your policy.
# Portal return URL is set in code (/platform/settings?billing=1); deep links use subscription_update / subscription_cancel flows.

 # I have local test mode versions of these for my AI Trader Sandbox in Stripe
# Supporter plan price IDs (create in Stripe Dashboard with metadata tier=supporter)
STRIPE_SUPPORTER_MONTHLY_PRICE_ID=
STRIPE_SUPPORTER_YEARLY_PRICE_ID=

# Outperformer plan price IDs (create in Stripe Dashboard with metadata tier=outperformer)
STRIPE_OUTPERFORMER_MONTHLY_PRICE_ID=
STRIPE_OUTPERFORMER_YEARLY_PRICE_ID=