{
  "framework": "nextjs",
  "crons": [
    { "path": "/api/cron/daily", "schedule": "35 13 * * 1-5" },
    { "path": "/api/cron/weekly-digest", "schedule": "0 21 * * 5" }
  ],
  "headers": [
    {
      "source": "/favicon.ico",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
